# 멍멍피트 환경변수 — .env.local 작성 가이드

# ─── 사이트 ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mungmungfit.kr

# ─── Vercel Deploy Hook (봇 → 갤러리 갱신 후 자동 재빌드) ──
# Vercel 대시보드 > Settings > Git > Deploy Hooks
MUNGMUNG_VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...

# ─── 자동화 (instagram-publishing-cycle) ────────────
# 텔레그램 봇 — 주인님 chat 으로 알림 발송용
# vibehub-media/.env.local 의 동일 키와 같은 값 사용
MUNGMUNG_BOT_TOKEN=
MUNGMUNG_CHAT_ID=8796384805

# ─── 마누스 짝 자동화 — Google Drive 접근 ───────────
# rclone remote 이름 + 작업 폴더 명
MUNGMUNG_DRIVE_REMOTE=gdrive
MUNGMUNG_DRIVE_FOLDER=멍멍피트

# ─── Supabase (자동화 보조용) ────────────────────────
# 마누스가 주로 쓰지만 자동화도 인사이트 폴링 시 필요할 수 있음
SUPABASE_URL=https://qufjlveukaoiokhpkhwj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Search Console verification (배포 환경에만 설정) ──
# Google Search Console > 속성 > 설정 > 소유권 확인 > HTML 태그 (content 값만)
GOOGLE_SITE_VERIFICATION=
# Naver Webmaster > 사이트 등록 > HTML 태그 (content 값만)
NAVER_SITE_VERIFICATION=

# ─── 배포 후 SEO 제출·모니터 자동화 ────────────────────
# Google Search Console 속성 URL. URL-prefix 속성이면 끝 슬래시까지 맞춘다.
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://mungmungfit.kr/
GOOGLE_SEARCH_CONSOLE_SITEMAP_URL=https://mungmungfit.kr/sitemap.xml
# 둘 중 하나만 설정하면 된다. JSON 문자열 또는 base64 JSON도 지원.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Naver IndexNow. key는 /indexnow-key.txt route에서도 사용된다.
NAVER_INDEXNOW_KEY=
NAVER_INDEXNOW_KEY_LOCATION=https://mungmungfit.kr/indexnow-key.txt
# 제휴 API accessToken이 있을 때만 Naver crawl verify/submit 실행.
NAVER_CRAWL_REQUEST_ACCESS_TOKEN=
